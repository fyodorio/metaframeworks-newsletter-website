---
import { Image } from 'astro:assets';
import aiUsagePolicyImage from '../images/ai-usage-policy.svg';

const today = new Date();
---

<footer>
  <p>
    &copy; {today.getFullYear()} Metaframeworks Records. All rights reserved.
  </p>

  <p>
    <a href="/ai-usage">
      <Image
        src={aiUsagePolicyImage}
        alt="Made by a human — go to the project's AI usage policy"
        height="48"
      />
    </a>
  </p>
</footer>

<style>
  footer {
    width: 100%;
    padding: 2em 1em;
    text-align: center;
    border-top: 2px solid black;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  p {
    display: flex;
    justify-content: center;
    margin: 0;
  }
</style>
